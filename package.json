{
  "name": "mapty-backend",
  "version": "1.0.0",
  "description": "Mapty PWA backend — REST API + Push Notifications",
  "main": "dist/index.js",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build":   "tsc",
    "start":   "node dist/index.js",
    "dev":     "ts-node-esm index.ts",
    "watch":   "tsc --watch"
  },
  "dependencies": {
    "cors":        "^2.8.5",
    "express":     "^4.19.2",
    "helmet":      "^7.1.0",
    "morgan":      "^1.10.0",
    "web-push":    "^3.6.7"
  },
  "devDependencies": {
    "@types/cors":      "^2.8.17",
    "@types/express":   "^4.17.21",
    "@types/morgan":    "^1.9.9",
    "@types/node":      "^20.12.0",
    "@types/web-push":  "^3.6.3",
    "ts-node":          "^10.9.2",
    "typescript":       "^5.4.0"
  }
}
